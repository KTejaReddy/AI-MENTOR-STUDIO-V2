# =============================================================================
# DATABASE
# =============================================================================
# SQLite (default — no external DB needed for development)
DATABASE_URL=sqlite:///./data/mentor_ai_studio.db
# Supabase PostgreSQL (production)
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings → Database → Connection string (URI)
# 3. Replace [YOUR-PASSWORD] with the database password
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# =============================================================================
# SUPABASE
# =============================================================================
# Find these in your Supabase project dashboard → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate secrets: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_EXPIRE_MINUTES=60
REFRESH_EXPIRE_DAYS=7

# =============================================================================
# GOOGLE OAUTH
# =============================================================================
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a new OAuth 2.0 Client ID (Web application)
# 3. Add Authorized redirect URI: http://localhost:8000/api/v1/auth/callback/google
# 4. Copy the Client ID and Client Secret here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# URLS
# =============================================================================
APP_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:5175"]

# =============================================================================
# APP
# =============================================================================
APP_NAME=Mentor AI Studio
APP_VERSION=2.1.0
LOG_LEVEL=INFO

# =============================================================================
# AI / GROQ API KEYS
# =============================================================================
# Sign up at https://console.groq.com to get API keys
# GROQ_API_KEY_1=gsk_your-key-here
